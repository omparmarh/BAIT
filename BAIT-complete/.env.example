# BAIT PRO ULTIMATE Configuration

# Backend URLs
BACKEND_URL=http://127.0.0.1:8000
FRONTEND_URL=http://127.0.0.1:5173

# LLM Configuration
LLM_API_BASE=http://localhost:1234/v1
LLM_API_KEY=lm-studio
OPENAI_API_KEY=your-openai-api-key-here

# Database
DATABASE_URL=sqlite:///bait.db
MEMORY_DB=memory.db

# Voice Control
VOICE_PROVIDER=google  # google, whisper, sphinx
PORCUPINE_API_KEY=your-porcupine-key-here  # Optional for wake word

# Vision/Camera
TESSERACT_PATH=C:\\Program Files\\Tesseract-OCR\\tesseract.exe  # Windows path

# API Integrations
# Spotify
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# Weather
OPENWEATHER_API_KEY=your-openweather-api-key

# News
NEWS_API_KEY=your-news-api-key

# Gmail (OAuth)
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS=calendar_credentials.json

# File Manager
FILE_INDEX_DIR=.file_index

# Workflows
WORKFLOW_STORAGE=workflows.json

# Features Toggle
ENABLE_VOICE=true
ENABLE_VISION=true
ENABLE_MEMORY=true
ENABLE_AUTOMATION=true
ENABLE_BROWSER_AGENT=true
ENABLE_DESKTOP_CONTROL=true
ENABLE_FILE_MANAGER=true
ENABLE_API_INTEGRATIONS=true

# Performance
MAX_WORKERS=4
CACHE_SIZE=1000
